{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "env": {
    "PYTHONIOENCODING": "utf-8",
    "PYTHONUTF8": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(py -m pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pre-commit:*)",
      "Bash(python -m pip install:*)",
      "Bash(py -m pip install:*)",
      "Bash(pip install:*)",
      "Bash(python -m tradefit:*)",
      "Bash(py -m tradefit:*)",
      "Bash(streamlit run:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)"
    ],
    "deny": [
      "Bash(git push:*)"
    ]
  }
}