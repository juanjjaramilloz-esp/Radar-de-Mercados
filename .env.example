# Copiar a .env y completar. NUNCA commitear .env.
# Key gratuita de UN Comtrade Plus (registro en https://comtradeplus.un.org/)
COMTRADE_API_KEY=

# Solo en despliegues detrás de un dominio/proxy propio (p. ej. Render + Cloudflare).
# Debe ser el host público sin esquema, como radar.ejemplo.com.
STREAMLIT_BROWSER_SERVER_ADDRESS=
